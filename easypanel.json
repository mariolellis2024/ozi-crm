{
  "$schema": "https://schemas.easypanel.io/v1/schema.json",
  "services": [
    {
      "type": "app",
      "data": {
        "projectName": "ozi-crm",
        "serviceName": "app",
        "source": {
          "type": "github",
          "owner": "mariolellis2024",
          "repo": "ozi-crm",
          "ref": "main",
          "path": "/"
        },
        "build": {
          "type": "dockerfile",
          "file": "Dockerfile"
        },
        "env": "DATABASE_URL=postgresql://ozi_user:$(POSTGRES_PASSWORD)@ozi-crm-postgres:5432/ozi_crm\nJWT_SECRET=$(JWT_SECRET)\nPORT=3001\nNODE_ENV=production",
        "deploy": {
          "replicas": 1,
          "resources": {
            "memoryReservation": 256,
            "memoryLimit": 512,
            "cpuReservation": 100,
            "cpuLimit": 500
          }
        },
        "domains": [
          {
            "host": "$(EASYPANEL_DOMAIN)",
            "port": 3001
          }
        ]
      }
    },
    {
      "type": "postgres",
      "data": {
        "projectName": "ozi-crm",
        "serviceName": "postgres",
        "image": "postgres:16-alpine",
        "password": "$(POSTGRES_PASSWORD)",
        "database": "ozi_crm",
        "user": "ozi_user"
      }
    }
  ]
}
