# ============================================
# OZI CRM — Environment Variables
# ============================================
# Copy this file to .env and fill in the values

# PostgreSQL
DATABASE_URL=postgresql://ozi_user:YOUR_PASSWORD@postgres:5432/ozi_crm
POSTGRES_PASSWORD=YOUR_PASSWORD

# JWT Secret (use a strong random string in production)
JWT_SECRET=YOUR_JWT_SECRET_HERE

# Server Port
PORT=3001

# Optional: External PostgreSQL port mapping
POSTGRES_PORT=5432
